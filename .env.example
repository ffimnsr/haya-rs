# Database connection URL (required)
DATABASE_URL=postgres://postgres:mysecretpassword@localhost:5432/haya

# JWT signing secret - must be at least 32 characters (required)
JWT_SECRET=replace-this-with-a-secret-at-least-32-characters-long

# JWT access token lifetime in seconds (default: 3600)
JWT_EXPIRY=3600

# Refresh token lifetime in seconds (default: 1209600, ~14 days)
REFRESH_TOKEN_EXPIRY=1209600

# Public URL of this server (default: http://localhost:9999)
SITE_URL=http://localhost:9999

# JWT issuer claim - falls back to SITE_URL if not set
# JWT_ISSUER=http://localhost:9999

# Port to listen on (default: 9999)
PORT=9999

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Skip email verification on signup (default: false)
MAILER_AUTOCONFIRM=false

# Site display name shown in email templates.
SITE_NAME=Haya

# SMTP settings — comment out SMTP_HOST to disable email sending entirely.
# The defaults below work with MailHog (docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=false
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Haya
# SMTP_USERNAME=
# SMTP_PASSWORD=

# Optional: override built-in email templates with files from this directory.
# Supported files: confirm.html, confirm.txt, recovery.html, recovery.txt,
#                  magic_link.html, magic_link.txt
# EMAIL_TEMPLATES_DIR=./templates/email

# Fixed instance UUID - auto-generated on each start if not set
# INSTANCE_ID=00000000-0000-0000-0000-000000000000

# Enable development mode with insecure defaults (do NOT use in production)
# HAYA_DEV_MODE=1
