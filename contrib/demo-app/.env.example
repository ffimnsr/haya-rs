# Haya Auth Demo — environment variables
#
# Copy this file to .env.local and adjust as needed.
# Values prefixed with VITE_ are exposed to the browser bundle.

# Base URL for the haya-rs auth API.
# In development this defaults to /auth (proxied by Vite to localhost:9999).
# In production set this to your deployed haya-rs URL:
#   e.g.  VITE_HAYA_URL=https://auth.example.com
VITE_HAYA_URL=/auth
